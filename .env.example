NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
FDC_API_KEY=DEMO_KEY

# Billing is intentionally off for beta. Set to "true" only when the store
# products, RevenueCat project, Supabase migration, and webhooks are live.
NEXT_PUBLIC_BILLING_ENABLED=false
NEXT_PUBLIC_REVENUECAT_PUBLIC_API_KEY=
NEXT_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium
NEXT_PUBLIC_REVENUECAT_OFFERING_ID=
# Set this exact value as the Authorization header in RevenueCat Webhooks.
REVENUECAT_WEBHOOK_AUTHORIZATION=

# Optional comma-separated hostnames that may request the local Next dev server.
# Example: 192.168.1.20,10.0.0.5
NEXT_ALLOWED_DEV_ORIGINS=
# Optional. Leave empty to use the canonical production URL hardcoded in
# capacitor.config.ts (currently https://pace-nutrition.vercel.app). Only set
# this if you're pointing the installed Android app at a local dev server or
# preview deployment.
CAPACITOR_SERVER_URL=
